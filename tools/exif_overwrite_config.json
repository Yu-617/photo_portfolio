{
  "rules": [
    {
      "name": "film_body",
      "match": {
        "mode": "or",
        "conditions": [
          {"label": "IFD0:Model", "op": "eq", "value": "EZ Controller"},
          {"label": "IFD0:Model", "op": "eq", "value": "SP-3000"}
        ]
      },
      "set": [
        {"label": "IFD0:Model", "value": "Film"}
      ]
    },
    {
      "name": "old_lens",
      "match": {
        "mode": "or",
        "conditions": [
          {"label": "Exif:FNumber", "op": "eq", "value": "(0, 1)"},
          {"label": "Exif:FNumber", "op": "eq", "value": "(0, 0)"},
          {"label": "Exif:FNumber", "op": "eq", "value": "undef"},
          {"label": "Exif:ApertureValue", "op": "eq", "value": "(0, 0)"},
          {"label": "Exif:FNumber", "op": "regex", "value": "^(?:\\(?0[\\/,\\s]*1\\)?|0)$"},
          {"label": "Exif:LensSpecification", "op": "contains", "value": "0, 0"},
          {"label": "Exif:LensInfo", "op": "regex", "value": "f/\\?"}
        ]
      },
      "set": [
        {"label": "LensModel", "value": "Super-Multi-Coated Takumar 55mm F1.8"},
        {"label": "Exif:FNumber", "value": "(0, 1)"}
      ]
    },
    {
      "name": "clear_lens_for_iphone_se3",
      "match": {
        "mode": "and",
        "conditions": [
          {"label": "IFD0:Model", "op": "eq", "value": "iPhone SE (3rd generation)"}
        ]
      },
      "set": [
        {"label": "LensModel", "value": ""}
      ]
    }
  ]
}

